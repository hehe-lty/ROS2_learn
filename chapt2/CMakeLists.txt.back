cmake_minimum_required(VERSION 3.8)
project(ros2_cpp)
add_executable(ros2_cpp_node ros2_cpp_node.cpp)

find_package(rclcpp REQUIRED) #直接查找到对应的头文件和库文件
message(STATUS ${rclcpp_INCLUDE_DIRS}) #打印头文件路径
message(STATUS ${rclcpp_LIBRARIES}) #打印库文件路径

target_include_directories(ros2_cpp_node PUBLIC ${rclcpp_INCLUDE_DIRS}) #添加头文件
target_link_libraries(ros2_cpp_node ${rclcpp_LIBRARIES}) #链接库文件